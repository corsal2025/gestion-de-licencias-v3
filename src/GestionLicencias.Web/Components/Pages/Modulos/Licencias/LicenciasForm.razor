@page "/modulos/licencias/crear"
@page "/modulos/licencias/editar/{Id:int}"
@rendermode InteractiveServer
@inject ITramiteService<TramiteLicencia> ModuloService
@inject NavigationManager Nav
@inject SesionUsuario Sesion
@inject IJSRuntime JS

<PageTitle>@(Id == 0 ? "Nuevo registro" : "Editar registro") — MODELO POWERBI</PageTitle>

<AuthGuard>
<div class="f8-wrapper f8-form">
    <div class="f8-topbar">
        <h2>@(Id == 0 ? "Nuevo registro" : "Editar registro")</h2>
        <div class="f8-actions">
            <button class="f8-btn" @onclick="Volver">Volver a la lista</button>
        </div>
    </div>

    @if (MostrarToastDomicilio)
    {
        <div class="f8-toast" @onanimationend="() => MostrarToastDomicilio = false">
            AVISO: Se ha registrado que NO se solicita cambio de domicilio para este registro.
        </div>
    }

    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="f8-msg @(EsError ? "f8-msg-error" : "f8-msg-ok")">@Mensaje</div>
    }

    @if (Modelo is null)
    {
        <p>Cargando...</p>
    }
    else
    {
        <fieldset>
            <legend>Contribuyente y citación</legend>
            <div class="f8-form-grid">
                <div class="f8-field">
                    <label>NOMBRE</label>
                    <input @bind="Modelo.Nombre" />
                </div>
                <div class="f8-field">
                    <label>APELLIDO</label>
                    <input @bind="Modelo.Apellido" />
                </div>
                <div class="f8-field">
                    <label>NOMBRE COMPLETO</label>
                    <input value="@Modelo.NombreCompleto" readonly />
                </div>
                <div class="f8-field">
                    <label>RUT</label>
                    <input @bind="Modelo.RUT" placeholder="11.111.111-1" />
                </div>
                <div class="f8-field">
                    <label>FECHA DE LA CITACIÓN</label>
                    <input type="date" @bind="Modelo.FechaCitacion" @bind:format="yyyy-MM-dd" />
                </div>
                <div class="f8-field">
                    <label>TELÉFONO</label>
                    <input placeholder="+56 9..." @bind="Modelo.Telefono" />
                </div>
                <div class="f8-field">
                    <label>LUGAR DE ATENCIÓN</label>
                    <select @bind="Modelo.LugarAtencion" @bind:after="OnLugarAtencionChanged">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.LugaresAtencion)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
                <div class="f8-field">
                    <label>ASISTE</label>
                    <select @bind="Modelo.Asiste" @bind:after="OnAsisteChanged">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.SiNo)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
            </div>
        </fieldset>

        @if (Modelo.ProcesoBloqueado)
        {
            <div class="f8-msg f8-msg-error">
                ⛔ PROCESO BLOQUEADO: @Modelo.MotivoBloqueo.
                @if (Sesion.EsPrivilegiado)
                {
                    <button class="f8-btn" style="margin-left:1rem;" @onclick="Desbloquear">Desbloquear</button>
                }
                @if (BloqueadoPorRechazoOJuzgado(Modelo))
                {
                    <button class="f8-btn" style="margin-left:.5rem;" @onclick="EnviarCorreoBloqueoContribuyente">Enviar correo</button>
                }
                else
                {
                    <span>Debe realizar el trámite nuevamente desde cero o solicitar el desbloqueo a una jefatura.</span>
                }
            </div>
        }

        <fieldset>
            <legend>Carpeta</legend>
            <div class="f8-form-grid">
                <div class="f8-field">
                    <label>FECHA ÚLTIMA CARPETA</label>
                    <input type="date" @bind="Modelo.FechaUltimaCarpeta" @bind:format="yyyy-MM-dd" @bind:after="ActualizarEstadoCarpeta" />
                </div>
                <div class="f8-field">
                    <label>ESTADO DE LA CARPETA</label>
                    <select @bind="Modelo.EstadoCarpeta" @bind:after="OnEstadoCarpetaChanged">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.EstadosCarpeta)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
                <div class="f8-field">
                    <label>CAMBIO DE DOMICILIO PEDIDO</label>
                    <select @bind="Modelo.CambioDomicilioPedido" @bind:after="OnCambioDomicilioPedidoChanged">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.SiNo)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
                <div class="f8-field">
                    <label>CIUDADES</label>
                    <div class="ta-autocomplete">
                        <input placeholder="Buscar ciudad..."
                               value="@(Modelo.CiudadCambioDomicilio ?? "")"
                               @oninput="FiltrarCiudadForm"
                               @onfocus="() => CiudadFormAbierto = true" />
                        @if (CiudadFormAbierto)
                        {
                            var opciones = FiltrarCiudades(FiltroCiudadForm);
                            if (opciones.Length > 0)
                            {
                                <div class="ta-autocomplete-list">
                                    @foreach (var c in opciones)
                                    {
                                        <div @onclick="() => SeleccionarCiudadForm(c)">@c</div>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>
                <div class="f8-field">
                    <label>FECHA DIGITALIZACIÓN CARPETA</label>
                    <input type="date" @bind="Modelo.FechaDigitalizacionCarpeta" @bind:format="yyyy-MM-dd" />
                </div>
                <div class="f8-field">
                    <label>FECHA SUBIDA A CONASET</label>
                    <input type="date" @bind="Modelo.FechaSubidaConaset" @bind:format="yyyy-MM-dd" readonly class="ta-cell-readonly" />
                </div>
                <div class="f8-field">
                    <label>CARPETA PEDIDA</label>
                    <select @bind="Modelo.CarpetaPedida">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.SiNo)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
            </div>
        </fieldset>

        <fieldset disabled="@IdoneidadDeshabilitadaFormulario">
            <legend>Idoneidad moral</legend>
            <div class="f8-form-grid">
                <div class="f8-field">
                    <label>IDONEIDAD MORAL</label>
                    <div style="display:flex;gap:.5rem;align-items:center;">
                        <select @bind="Modelo.IdoneidadMoral" @bind:after="OnIdoneidadMoralChanged" style="flex:1;">
                            <option value="">—</option>
                            @foreach (var v in Catalogos.IdoneidadMoral)
                            {
                                <option value="@v">@v</option>
                            }
                        </select>
                        @if (PuedeGestionarJuzgado)
                        {
                            @if (EsBloqueoPorJuzgado(Modelo))
                            {
                                <button type="button" class="f8-btn" title="Desbloquear proceso por Juzgado" @onclick="DesbloquearJuzgado">Desbloquear Juzgado</button>
                            }
                            else
                            {
                                <button type="button" class="f8-btn" title="Bloquear proceso por Juzgado" @onclick="BloquearJuzgado">Bloquear Juzgado</button>
                            }
                        }
                    </div>
                </div>
                <div class="f8-field">
                    <label>CONTACTADO</label>
                    <select @bind="Modelo.Contactado">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.SiNo)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
                <div class="f8-field">
                    <label>NOTIFICADO</label>
                    <select @bind="Modelo.Notificado">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.SiNo)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
            </div>
        </fieldset>

        <fieldset>
            <legend>Cambio de domicilio</legend>
            <div class="f8-form-grid">
                <div class="f8-field">
                    <label>LUGAR DE ORIGEN CAMBIO DOMICILIO</label>
                    <input @bind="Modelo.LugarOrigenCambioDomicilio" />
                </div>
                <div class="f8-field">
                    <label>PETICIÓN DE CAMBIO DOMICILIO</label>
                    <select @bind="Modelo.PeticionCambioDomicilio">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.SiNo)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
                <div class="f8-field">
                    <label>CAMBIO DOMICILIO PEDIDO POR</label>
                    <select @bind="Modelo.CambioDomicilioPedidoPor">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.CambioDomicilioPedidoPor)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
            </div>
        </fieldset>

        <fieldset disabled="@Modelo.ProcesoBloqueado">
            <legend>F8</legend>
            <div class="f8-form-grid">
                <div class="f8-field">
                    <label>FOLIO (F8)</label>
                    <input @bind="Modelo.FolioF8" />
                </div>
                <div class="f8-field">
                    <label>FECHA PENÚLTIMA CARPETA</label>
                    <input type="date" @bind="Modelo.FechaPenultimaCarpeta" @bind:format="yyyy-MM-dd" />
                </div>
                <div class="f8-field">
                    <label>ESTADO DEL F8</label>
                    <select value="@Modelo.EstadoF8" @onchange="OnEstadoF8Changed">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.EstadosF8)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
            </div>
        </fieldset>

        <fieldset disabled="@Modelo.ProcesoBloqueado">
            <legend>Otorgamiento e impresión</legend>
            <div class="f8-form-grid">
                <div class="f8-field">
                    <label>OTORGAMIENTO</label>
                    <select @bind="Modelo.Otorgamiento">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.Otorgamientos)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
                <div class="f8-field">
                    <label>FOLIO LICENCIA</label>
                    <input @bind="Modelo.FolioLicencia" />
                </div>
                <div class="f8-field">
                    <label>FECHA IMPRESIÓN</label>
                    <input type="date" @bind="Modelo.FechaImpresion" @bind:format="yyyy-MM-dd" />
                </div>
                <div class="f8-field">
                    <label>IMPRESA POR</label>
                    <select @bind="Modelo.ImpresaPor">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.ImpresaPor)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
            </div>
        </fieldset>

        <fieldset disabled="@Modelo.ProcesoBloqueado">
            <legend>PAM y entrega</legend>
            <div class="f8-form-grid">
                <div class="f8-field">
                    <label>BAJADA A PAM</label>
                    <select @bind="Modelo.BajadaAPam">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.SiNo)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
                <div class="f8-field">
                    <label>BAJADA POR</label>
                    <input @bind="Modelo.BajadaPor" />
                </div>
                <div class="f8-field">
                    <label>FECHA RECEPCIÓN PAM</label>
                    <input type="date" @bind="Modelo.FechaRecepcionPam" @bind:format="yyyy-MM-dd" />
                </div>
                <div class="f8-field">
                    <label>RECIBIDA EN PAM POR</label>
                    <select @bind="Modelo.RecibidaEnPamPor">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.RecibidaEnPamPor)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
                <div class="f8-field">
                    <label>CONTACTADO CONTRIBUYENTE PARA ENTREGA</label>
                    <select @bind="Modelo.ContactadoParaEntrega">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.SiNo)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
                <div class="f8-field">
                    <label>FECHA DE ENTREGA</label>
                    <input type="date" @bind="Modelo.FechaEntrega" @bind:format="yyyy-MM-dd" />
                </div>
            </div>
        </fieldset>

        <fieldset>
            <legend>Datos personales</legend>
            <div class="f8-form-grid">
                <div class="f8-field">
                    <label>SEXO</label>
                    <select @bind="Modelo.Sexo">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.Sexos)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
                <div class="f8-field">
                    <label>FECHA DE NACIMIENTO</label>
                    <FechaNacimientoSelector @bind-value="Modelo.FechaNacimiento" />
                </div>
                <div class="f8-field">
                    <label>EDAD</label>
                    <input value="@(Modelo.Edad?.ToString() ?? "—")" readonly />
                </div>
                <div class="f8-field">
                    <label>TIPO DE LICENCIA</label>
                    <select @bind="Modelo.TipoLicencia">
                        <option value="">—</option>
                        @foreach (var v in Catalogos.TiposLicencia)
                        {
                            <option value="@v">@v</option>
                        }
                    </select>
                </div>
            </div>
        </fieldset>

        <fieldset>
            <legend>Observaciones</legend>
            <div class="f8-field">
                <label>OBSERVACIONES</label>
                <input @bind="Modelo.Observaciones" />
            </div>
        </fieldset>

        <div class="f8-actions" style="margin-top:1rem;">
            <button class="f8-btn f8-btn-primary" @onclick="Guardar" disabled="@Guardando">
                @(Guardando ? "Guardando..." : "Guardar")
            </button>
            <button class="f8-btn" @onclick="Volver">Cancelar</button>
        </div>
    }
</div>
</AuthGuard>

@code {
    [Parameter] public int Id { get; set; }

    private TramiteLicencia? Modelo;
    private string Mensaje = "";
    private bool EsError = false;
    private bool Guardando = false;
    private bool MostrarToastDomicilio = false;
    private bool CiudadFormAbierto = false;
    private string FiltroCiudadForm = "";
    private bool PuedeGestionarJuzgado => Sesion.Actual?.Rol is Roles.Administrador or Roles.Jefatura;
    private bool IdoneidadDeshabilitadaFormulario =>
        Modelo is null || NoEdita(Roles.IdoneidadMoral) || (Modelo.ProcesoBloqueado && !PuedeGestionarJuzgado);

    /// <summary>Fecha máxima para nacimiento: 17 años atrás desde hoy.</summary>
    private string MaxFechaNacimiento => DateTime.Today.AddYears(-17).ToString("yyyy-MM-dd");

    private bool NoEdita(string seccion) => !Sesion.PuedeEditar(seccion);

    protected override async Task OnParametersSetAsync()
    {
        if (Id == 0)
        {
            Modelo = new TramiteLicencia
            {
                RUT = "",
                Nombre = "",
                Email = "",
                Telefono = "",
                UsuarioId = "SISTEMA",
                TipoModulo = "TramiteLicencia"
            };
        }
        else
        {
            Modelo = await ModuloService.ObtenerPorIdAsync(Id);
            if (Modelo is null)
            {
                Mensaje = $"No se encontró el registro {Id}.";
                EsError = true;
            }
            else
            {
                Modelo.RUT = BaseTramite.FormatearRut(Modelo.RUT);
            }
        }
    }

    private static string NormalizarTelefono(string? telefono)
    {
        var t = (telefono ?? "").Trim();
        if (t.Length == 0) return t;
        var digits = System.Text.RegularExpressions.Regex.Replace(t, @"\D", "");
        if (digits.StartsWith("56") && digits.Length > 9)
            digits = digits[2..];
        return $"+56 - {digits}";
    }

    private void OnAsisteChanged()
    {
    }

    private void OnLugarAtencionChanged()
    {
        if (Modelo is null) return;
        if (Modelo.LugarAtencion == "PLACILLA")
            Modelo.ImpresaPor = "SANDRA";
        else
            Modelo.ImpresaPor = null;
    }

    private async Task OnIdoneidadMoralChanged()
    {
        if (Modelo is null) return;
        if (Modelo.IdoneidadMoral == "JUZGADO")
        {
            var nombre = Modelo.NombreCompleto;
            var msg = $"ATENCIÓN: El postulante {nombre} (RUT: {Modelo.RUT}) ha sido derivado a JUZGADO. Su proceso quedará bloqueado.";
            await JS.InvokeVoidAsync("alert", msg);
        }
    }

    private static bool BloqueadoPorRechazoOJuzgado(TramiteLicencia? tramite) =>
        tramite is not null && !tramite.DesbloqueoAdministrativo &&
        (tramite.IdoneidadMoral == "REPROBADA" || tramite.IdoneidadMoral == "JUZGADO");

    private async Task EnviarCorreoBloqueoContribuyente()
    {
        if (Modelo is null || !BloqueadoPorRechazoOJuzgado(Modelo))
            return;

        if (string.IsNullOrWhiteSpace(Modelo.Email))
        {
            await JS.InvokeVoidAsync("alert", "El contribuyente no tiene correo registrado.");
            return;
        }

        var nombre = string.IsNullOrWhiteSpace(Modelo.NombreCompleto)
            ? $"{Modelo.Nombre} {Modelo.Apellido}".Trim()
            : Modelo.NombreCompleto;
        var rut = Modelo.RUT ?? "";
        var motivo = Modelo.IdoneidadMoral == "JUZGADO"
            ? "derivación a Juzgado"
            : "rechazo de idoneidad moral";

        var asunto = Uri.EscapeDataString($"Estado de su trámite de licencia — {rut}");
        var cuerpo = Uri.EscapeDataString(
$@"Estimado(a) {nombre},

Le informamos que su trámite de licencia de conducir se encuentra temporalmente bloqueado por {motivo}.

RUT: {rut}
Estado actual: {Modelo.IdoneidadMoral}

Para más información, por favor comuníquese con la Municipalidad de Valparaíso, Departamento de Licencias de Conducir.

Saludos cordiales,
Municipalidad de Valparaíso
Departamento de Licencias de Conducir");

        var destinatario = Uri.EscapeDataString(Modelo.Email.Trim());
        var mailto = $"mailto:{destinatario}?subject={asunto}&body={cuerpo}";
        await JS.InvokeVoidAsync("eval", $"window.open('{mailto}', '_blank')");
    }

    private static bool EsBloqueoPorJuzgado(TramiteLicencia? tramite) =>
        tramite is not null && tramite.IdoneidadMoral == "JUZGADO" && !tramite.DesbloqueoAdministrativo;

    private async Task BloquearJuzgado()
    {
        if (Modelo is null || !PuedeGestionarJuzgado) return;

        Modelo.IdoneidadMoral = "JUZGADO";
        Modelo.DesbloqueoAdministrativo = false;
        Modelo.DesbloqueadoPor = null;
        Modelo.FechaDesbloqueo = null;

        try
        {
            await ModuloService.ActualizarAsync(Modelo);
            Mensaje = "Registro bloqueado por Juzgado.";
            EsError = false;
            await JS.InvokeVoidAsync("alert", $"ATENCIÓN: El postulante {Modelo.NombreCompleto} (RUT: {Modelo.RUT}) ha sido derivado a JUZGADO. Su proceso quedó bloqueado.");
        }
        catch (Exception ex)
        {
            Mensaje = $"Error al bloquear por Juzgado: {ex.Message}";
            EsError = true;
        }
    }

    private async Task DesbloquearJuzgado()
    {
        if (Modelo is null || !PuedeGestionarJuzgado) return;

        Modelo.DesbloqueoAdministrativo = true;
        Modelo.DesbloqueadoPor = Sesion.Actual?.NombreUsuario ?? "SISTEMA";
        Modelo.FechaDesbloqueo = DateTime.UtcNow;

        try
        {
            await ModuloService.ActualizarAsync(Modelo);
            Mensaje = "Bloqueo por Juzgado levantado administrativamente.";
            EsError = false;
        }
        catch (Exception ex)
        {
            Mensaje = $"Error al desbloquear Juzgado: {ex.Message}";
            EsError = true;
        }
    }

    private void OnEstadoCarpetaChanged()
    {
        if (Modelo is null) return;
        if (Modelo.EstadoCarpeta == "SUBIDA A CONASET")
            Modelo.FechaSubidaConaset = DateTime.Today;
        else
            Modelo.FechaSubidaConaset = null;

        if (!Modelo.CambioDomicilioActivo)
        {
            Modelo.CambioDomicilioPedido = null;
            Modelo.CiudadCambioDomicilio = null;
            Modelo.LugarOrigenCambioDomicilio = null;
        }
        else
        {
            Modelo.LugarOrigenCambioDomicilio = Modelo.CiudadCambioDomicilio;
        }
    }

    private async Task OnCambioDomicilioPedidoChanged()
    {
        if (Modelo is null) return;
        if (Modelo.CambioDomicilioPedido == "SI")
        {
            Modelo.LugarOrigenCambioDomicilio = Modelo.CiudadCambioDomicilio;
        }
        else
        {
            Modelo.LugarOrigenCambioDomicilio = null;
        }

        if (Modelo.CambioDomicilioPedido == "NO")
        {
            MostrarToastDomicilio = true;
            StateHasChanged();
            await Task.Delay(4000);
            MostrarToastDomicilio = false;
            StateHasChanged();
        }
    }

    private static string[] FiltrarCiudades(string filtro)
    {
        if (string.IsNullOrWhiteSpace(filtro))
            return Catalogos.CiudadesChile.Take(20).ToArray();
        return Catalogos.CiudadesChile
            .Where(c => c.Contains(filtro.ToUpperInvariant()))
            .Take(20)
            .ToArray();
    }

    private void FiltrarCiudadForm(ChangeEventArgs e)
    {
        FiltroCiudadForm = e.Value?.ToString() ?? "";
        CiudadFormAbierto = true;
        
        if (Modelo is not null)
        {
            var valor = string.IsNullOrWhiteSpace(FiltroCiudadForm) ? null : FiltroCiudadForm.ToUpperInvariant();
            Modelo.CiudadCambioDomicilio = valor;
            if (Modelo.CambioDomicilioActivo)
            {
                Modelo.LugarOrigenCambioDomicilio = valor;
            }
            else
            {
                Modelo.LugarOrigenCambioDomicilio = null;
            }
        }
    }

    private void SeleccionarCiudadForm(string ciudad)
    {
        if (Modelo is null) return;
        Modelo.CiudadCambioDomicilio = ciudad;
        if (Modelo.CambioDomicilioActivo)
        {
            Modelo.LugarOrigenCambioDomicilio = ciudad;
        }
        else
        {
            Modelo.LugarOrigenCambioDomicilio = null;
        }
        CiudadFormAbierto = false;
        FiltroCiudadForm = "";
    }

    private void ActualizarEstadoCarpeta()
    {
        if (Modelo is null) return;
        Modelo.EstadoCarpeta = Modelo.FechaUltimaCarpeta.HasValue
            && Modelo.FechaUltimaCarpeta.Value >= new DateTime(2023, 7, 1)
                ? "SE ENCUENTRA EN OF.43"
                : "SE ENCUENTRA EN ARCHIVOS";

        if (!Modelo.CambioDomicilioActivo)
        {
            Modelo.CambioDomicilioPedido = null;
            Modelo.CiudadCambioDomicilio = null;
            Modelo.LugarOrigenCambioDomicilio = null;
        }
    }

    private void OnEstadoF8Changed(ChangeEventArgs e)
    {
        if (Modelo is null) return;
        Modelo.EstadoF8 = e.Value?.ToString() ?? "";
        
        if (Modelo.EstadoF8 == "SUBIDA A CONASET")
        {
            Modelo.EstadoCarpeta = "SUBIDA CON F8";
            Modelo.FechaSubidaConaset = DateTime.Today;
        }
        else
        {
            Modelo.FechaSubidaConaset = null;
        }
    }

    private async Task Desbloquear()
    {
        if (Modelo is null) return;
        Modelo.DesbloqueoAdministrativo = true;
        Modelo.DesbloqueadoPor = Sesion.Actual?.NombreUsuario ?? "SISTEMA";
        Modelo.FechaDesbloqueo = DateTime.UtcNow;
        if (Modelo.Estado == "BLOQUEADO - NO ASISTIÓ") Modelo.Estado = "En Proceso";
        
        try
        {
            await ModuloService.ActualizarAsync(Modelo);
            Mensaje = "Trámite desbloqueado administrativamente con éxito.";
            EsError = false;
        }
        catch (Exception ex)
        {
            Mensaje = $"Error al desbloquear: {ex.Message}";
            EsError = true;
        }
    }

    private async Task Guardar()
    {
        if (Modelo is null) return;

        Modelo.RUT = BaseTramite.FormatearRut(Modelo.RUT);
        Modelo.Telefono = NormalizarTelefono(Modelo.Telefono);

        var (ok, msg) = ModuloService.ValidarTramite(Modelo);
        if (!ok)
        {
            Mensaje = msg;
            EsError = true;
            return;
        }

        Guardando = true;
        try
        {
            Modelo.UsuarioId = Sesion.Actual?.NombreUsuario ?? "SISTEMA";
            if (Id == 0)
                await ModuloService.CrearAsync(Modelo);
            else
                await ModuloService.ActualizarAsync(Modelo);
            Nav.NavigateTo("/modulos/licencias");
        }
        catch (Exception ex)
        {
            Mensaje = $"Error al guardar: {ex.Message}";
            EsError = true;
        }
        finally
        {
            Guardando = false;
        }
    }

    private void Volver() => Nav.NavigateTo("/modulos/licencias");
}

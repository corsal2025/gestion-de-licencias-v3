@page "/modulos/licencias"
@rendermode InteractiveServer
@using System.Globalization
@using ClosedXML.Excel
@inject ITramiteService<TramiteLicencia> ModuloService
@inject TramiteLicenciaService StatsService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject SesionUsuario Sesion

<PageTitle>Gestionador de Licencias</PageTitle>

<AuthGuard>
<div class="f8-wrapper">
    <div class="f8-topbar">
        <h2>Gestionador de Licencias</h2>
        <div class="f8-actions">
            <button class="f8-btn" @onclick="ExportarXls">Exportar Excel</button>
            <button class="f8-btn" @onclick="AbrirPdf">Descargar PDF</button>
            <button class="f8-btn" @onclick="AbrirPegado">Subir con Excel</button>
            <button class="f8-btn" @onclick="IrSeguimiento">Seguimiento</button>
            <button class="f8-btn" @onclick="IrEstadisticas">Estadísticas</button>
            <button class="f8-btn f8-btn-primary" @onclick="Nuevo">Nuevo registro</button>
        </div>
    </div>

    @if (Estadisticas.Count > 0)
    {
        <div class="f8-stats">
            <div class="f8-stat"><strong>@TotalResultados</strong> Total</div>
            @foreach (var kv in Estadisticas.OrderByDescending(k => k.Value))
            {
                <div class="f8-stat @ClaseStat(kv.Key)"><strong>@kv.Value</strong> @kv.Key</div>
            }
        </div>
    }

    @if (Seleccionados.Count > 0)
    {
        <div class="f8-bulk-bar">
            <span>@Seleccionados.Count registro(s) seleccionados</span>
            <button class="f8-btn f8-btn-danger" @onclick="EliminarSeleccionados">Eliminar seleccionados</button>
        </div>
    }

    <div class="f8-filters">
        <input placeholder="Buscar por RUT, nombre, apellido o correo..."
               value="@FiltroTermino" @oninput="OnFiltroTerminoChanged" @onkeyup="OnKeyUp" />
        <select @bind="FiltroOtorgamiento">
            <option value="">— OTORGAMIENTO —</option>
            @foreach (var o in Catalogos.Otorgamientos)
            {
                <option value="@o">@o</option>
            }
        </select>
        <select @bind="FiltroEstadoCarpeta">
            <option value="">— ESTADO DE LA CARPETA —</option>
            @foreach (var e in Catalogos.EstadosCarpeta)
            {
                <option value="@e">@e</option>
            }
        </select>
        <button class="f8-btn f8-btn-primary" @onclick="BuscarClick">Buscar</button>
        <button class="f8-btn" @onclick="Limpiar">Limpiar</button>
    </div>

    @if (MostrarToastDomicilio)
    {
        <div class="f8-toast" @onanimationend="() => MostrarToastDomicilio = false">
            AVISO: Se ha registrado que NO se solicita cambio de domicilio para este registro.
        </div>
    }

    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="f8-msg @(EsError ? "f8-msg-error" : "f8-msg-ok")">@Mensaje</div>
    }

    @if (Cargando)
    {
        <p>Cargando...</p>
    }
    else if (Registros.Count == 0)
    {
        <p>No hay registros.</p>
    }
    else
    {
        <div class="f8-scroll">
            <table class="f8-table">
                <thead>
                    <tr class="ta-grupos">
                        <th colspan="12" class="grp-contrib">DATOS PERSONALES CONTRIBUYENTE Y CITACIÓN</th>
                        <th colspan="7" class="grp-carpeta sep-carpeta">CARPETA</th>
                        <th colspan="3" class="grp-idoneidad sep-idoneidad">IDONEIDAD MORAL</th>
                        <th colspan="5" class="grp-domicilio sep-domicilio">CAMBIO DE DOMICILIO</th>
                        <th colspan="3" class="grp-f8 sep-f8">F8</th>
                        <th colspan="4" class="grp-otorg sep-otorg">OTORGAMIENTO E IMPRESIÓN</th>
                        <th colspan="6" class="grp-pam sep-pam">PAM Y ENTREGA</th>
                        <th class="grp-acciones sep-acciones"></th>
                    </tr>
                    <tr class="ta-cols">
                        <th class="ta-check"><input type="checkbox" checked="@TodosSeleccionados" @onchange="ToggleSeleccionTodos" /></th>
                        <th class="ta-fix1">NOMBRE COMPLETO</th>
                        <th class="ta-fix2" style="text-align:center;">RUT</th>
                        <th>SEXO</th>
                        <th>FECHA DE NACIMIENTO</th>
                        <th>EDAD</th>
                        <th>TIPO DE LICENCIA</th>
                        <th>FECHA DE LA CITACIÓN</th>
                        <th>TELÉFONO</th>
                        <th>CORREO ELECTRÓNICO</th>
                        <th>LUGAR DE ATENCIÓN</th>
                        <th>ASISTE</th>
                        <th class="sep-carpeta">FECHA ÚLTIMA CARPETA</th>
                        <th>ESTADO DE LA CARPETA</th>
                        <th>CORREO DIRECTOR</th>
                        <th>CIUDADES</th>
                        <th>FECHA DIGITALIZACIÓN CARPETA</th>
                        <th>FECHA SUBIDA A CONASET</th>
                        <th>CARPETA PEDIDA</th>
                        <th class="sep-idoneidad">IDONEIDAD MORAL</th>
                        <th>CONTACTADO</th>
                        <th>NOTIFICADO</th>
                        <th class="sep-domicilio">LUGAR DE ORIGEN CAMBIO DOMICILIO</th>
                        <th>PETICIÓN DE CAMBIO DOMICILIO</th>
                        <th>CAMBIO DE DOMICILIO PEDIDO POR</th>
                        <th>CAMBIO DE DOMICILIO PEDIDO</th>
                        <th>SOLICITAR CARPETA</th>
                        <th class="sep-f8">FOLIO (F8)</th>
                        <th>FECHA PENÚLTIMA CARPETA</th>
                        <th>ESTADO DEL F8</th>
                        <th class="sep-otorg">OTORGAMIENTO</th>
                        <th>FOLIO LICENCIA</th>
                        <th>FECHA IMPRESIÓN</th>
                        <th>IMPRESA POR</th>
                        <th class="sep-pam">BAJADA A PAM</th>
                        <th>BAJADA POR</th>
                        <th>FECHA RECEPCIÓN PAM</th>
                        <th>RECIBIDA EN PAM POR</th>
                        <th>CONTACTADO CONTRIBUYENTE PARA ENTREGA</th>
                        <th>FECHA DE ENTREGA</th>
                        <th class="sep-acciones">ACCIONES</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Registros)
                    {
                        <tr class="@ClaseFila(r)">
                            <td class="ta-check"><input type="checkbox" checked="@Seleccionados.Contains(r.Id)" @onchange="() => ToggleSeleccion(r.Id)" /></td>
                            <td class="ta-fix1"><span class="ta-readonly">@r.NombreCompleto</span></td>
                            <td class="ta-fix2">
                                <input class="ta-cell ta-mono @(RutsDuplicados.Contains(r.RUT) ? "f8-dup" : "")"
                                       style="width:130px;min-width:130px;text-align:center;"
                                       @bind="r.RUT" @bind:after="() => GuardarFila(r)" />
                                @if (RutsDuplicados.Contains(r.RUT))
                                {
                                    <span class="f8-dup">⚠</span>
                                }
                            </td>
                            <td>
                                <select class="ta-cell ta-w-md" @bind="r.Sexo" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.Sexos)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td><FechaNacimientoSelector @bind-value="r.FechaNacimiento" @bind-value:after="() => GuardarFila(r)" /></td>
                            <td class="ta-center"><span class="ta-readonly">@(r.Edad?.ToString() ?? "—")</span></td>
                            <td>
                                <select class="ta-cell ta-w-sm" @bind="r.TipoLicencia" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.TiposLicencia)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td><input type="date" class="ta-cell ta-cell-date" @bind="r.FechaCitacion" @bind:after="() => GuardarFila(r)" /></td>
                            <td><input class="ta-cell ta-w-md ta-phone" placeholder="+56 9..." @bind="r.Telefono" @bind:after="() => GuardarFila(r)" /></td>
                            <td><input class="ta-cell ta-w-md ta-email" list="ta-email-dl" @bind="r.Email" @bind:after="() => GuardarFila(r)" /></td>
                            <td>
                                <select class="ta-cell ta-w-md" @bind="r.LugarAtencion" @bind:after="() => OnLugarAtencionChanged(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.LugaresAtencion)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <select class="ta-cell ta-w-sm @ClaseSiNo(r.Asiste)" @bind="r.Asiste" @bind:after="() => OnAsisteChanged(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.SiNo)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td class="sep-carpeta"><input type="date" class="ta-cell ta-cell-date" disabled="@(r.ProcesoBloqueado || NoEdita(Roles.Carpeta))" @bind="r.FechaUltimaCarpeta" @bind:after="() => ActualizarEstadoCarpeta(r)" /></td>
                            <td>
                                <select class="ta-cell ta-w-lg ta-estado @ClaseEstado(r.EstadoCarpeta)" disabled="@(r.ProcesoBloqueado || NoEdita(Roles.Carpeta))" @bind="r.EstadoCarpeta" @bind:after="() => OnEstadoCarpetaChanged(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.EstadosCarpeta)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td class="ta-cell-center">
                                @if (r.EstadoCarpeta == "CREAR OFICIO")
                                {
                                    <button type="button" class="f8-btn f8-btn-sm" title="Enviar correo al Director — certificado del contribuyente (próximamente)" disabled>✉</button>
                                }
                            </td>
                            <td class="ta-cell-center">
                                <div class="ta-autocomplete">
                                    <input class="ta-cell ta-w-md" placeholder="Buscar ciudad..."
                                           value="@(r.CiudadCambioDomicilio ?? "")"
                                           @oninput="(e) => FiltrarCiudadRapida(r, e)"
                                           @onchange="() => GuardarFila(r)"
                                           @onfocus="() => AbrirCiudadDropdown(r)" />
                                    @if (CiudadDropdownAbierto == r.Id && FiltroCiudadRapida.Length >= 0)
                                    {
                                        var opciones = FiltrarCiudades(FiltroCiudadRapida);
                                        if (opciones.Length > 0)
                                        {
                                            <div class="ta-autocomplete-list">
                                                @foreach (var c in opciones)
                                                {
                                                    <div @onclick="() => SeleccionarCiudadRapida(r, c)">@c</div>
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                            </td>
                            <td><input type="date" class="ta-cell ta-cell-date" disabled="@(r.ProcesoBloqueado || NoEdita(Roles.Carpeta))" @bind="r.FechaDigitalizacionCarpeta" @bind:after="() => GuardarFila(r)" /></td>
                            <td><input type="date" class="ta-cell ta-cell-date ta-cell-readonly" @bind="r.FechaSubidaConaset" readonly /></td>
                            <td>
                                <select class="ta-cell ta-w-sm @ClaseSiNo(r.CarpetaPedida)" disabled="@(r.ProcesoBloqueado || NoEdita(Roles.Carpeta))" @bind="r.CarpetaPedida" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.SiNo)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td class="sep-idoneidad">
                                <div style="display:flex;gap:.35rem;align-items:center;">
                                    <select class="ta-cell ta-w-md @ClaseAprobada(r.IdoneidadMoral)" disabled="@IdoneidadDeshabilitadaFila(r)" @bind="r.IdoneidadMoral" @bind:after="() => OnIdoneidadMoralChanged(r)">
                                        <option value="">—</option>
                                        @foreach (var v in Catalogos.IdoneidadMoral)
                                        {
                                            <option value="@v">@v</option>
                                        }
                                    </select>
                                    @if (r.IdoneidadMoral == "JUZGADO")
                                    {
                                        <span class="ta-alerta-juzgado">⚖ JUZGADO</span>
                                    }
                                    @if (PuedeGestionarJuzgado && r.IdoneidadMoral != "JUZGADO")
                                    {
                                        @if (r.IdoneidadMoral == "REPROBADA" && !r.DesbloqueoAdministrativo)
                                        {
                                            <button type="button" class="f8-btn f8-btn-sm" title="Desbloquear proceso REPROBADA" @onclick="() => DesbloquearJuzgado(r)">🔒</button>
                                        }
                                        else if (!r.IdoneidadBloqueante)
                                        {
                                            <button type="button" class="f8-btn f8-btn-sm" title="Bloquear proceso por Juzgado" @onclick="() => BloquearJuzgado(r)">🔓</button>
                                        }
                                    }
                                    @if (r.IdoneidadMoral == "JUZGADO" || r.IdoneidadMoral == "REPROBADA")
                                    {
                                        <button type="button"
                                                class="f8-btn f8-btn-sm"
                                                title="Enviar correo al contribuyente"
                                                @onclick="() => EnviarCorreoBloqueoContribuyente(r)">✉</button>
                                    }
                                </div>
                            </td>
                            <td>
                                <select class="ta-cell ta-w-sm @ClaseSiNo(r.Contactado)" disabled="@(r.ProcesoBloqueado || NoEdita(Roles.IdoneidadMoral))" @bind="r.Contactado" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.SiNo)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <select class="ta-cell ta-w-sm @ClaseSiNo(r.Notificado)" disabled="@(r.ProcesoBloqueado || NoEdita(Roles.IdoneidadMoral))" @bind="r.Notificado" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.SiNo)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td class="sep-domicilio ta-cell-center">
                                @if (r.CambioDomicilioActivo)
                                {
                                    <input class="ta-cell ta-w-md" @bind="r.LugarOrigenCambioDomicilio" @bind:after="() => GuardarFila(r)" />
                                }
                                else
                                {
                                    <span class="ta-cell ta-w-md" style="display:inline-block;text-align:center;"></span>
                                }
                            </td>
                            <td>
                                <select class="ta-cell ta-w-sm @ClaseSiNo(r.PeticionCambioDomicilio)" @bind="r.PeticionCambioDomicilio" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.SiNo)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <select class="ta-cell ta-w-md" @bind="r.CambioDomicilioPedidoPor" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.CambioDomicilioPedidoPor)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td class="ta-cell-center">
                                <select class="ta-cell ta-w-sm @ClaseSiNo(r.CambioDomicilioPedido)" @bind="r.CambioDomicilioPedido" @bind:after="() => OnCambioDomicilioPedidoChanged(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.SiNo)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(r.CiudadCambioDomicilio))
                                {
                                    <button class="f8-btn f8-btn-sm" title="Enviar correo para solicitar carpeta de @r.CiudadCambioDomicilio"
                                            @onclick="() => EnviarCorreoSolicitudCarpeta(r)">📧</button>
                                }
                            </td>
                            <td class="sep-f8"><input class="ta-cell ta-mono ta-w-sm" disabled="@r.ProcesoBloqueado" @bind="r.FolioF8" @bind:after="() => GuardarFila(r)" /></td>
                            <td><input type="date" class="ta-cell ta-cell-date" disabled="@r.ProcesoBloqueado" @bind="r.FechaPenultimaCarpeta" @bind:after="() => GuardarFila(r)" /></td>
                            <td>
                                <select class="ta-cell ta-w-md" disabled="@r.ProcesoBloqueado" value="@r.EstadoF8" @onchange="e => OnEstadoF8Changed(r, e)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.EstadosF8)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td class="sep-otorg">
                                <select class="ta-cell ta-w-md @ChipOtorgamiento(r.Otorgamiento)" disabled="@r.ProcesoBloqueado" @bind="r.Otorgamiento" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.Otorgamientos)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td><input class="ta-cell ta-mono ta-w-sm" disabled="@r.ProcesoBloqueado" @bind="r.FolioLicencia" @bind:after="() => GuardarFila(r)" /></td>
                            <td><input type="date" class="ta-cell ta-cell-date" disabled="@r.ProcesoBloqueado" @bind="r.FechaImpresion" @bind:after="() => GuardarFila(r)" /></td>
                            <td>
                                <select class="ta-cell ta-w-md" disabled="@r.ProcesoBloqueado" @bind="r.ImpresaPor" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.ImpresaPor)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td class="sep-pam">
                                <select class="ta-cell ta-w-sm @ClaseSiNo(r.BajadaAPam)" disabled="@r.ProcesoBloqueado" @bind="r.BajadaAPam" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.SiNo)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td><input class="ta-cell ta-w-sm" disabled="@r.ProcesoBloqueado" @bind="r.BajadaPor" @bind:after="() => GuardarFila(r)" /></td>
                            <td><input type="date" class="ta-cell ta-cell-date" disabled="@r.ProcesoBloqueado" @bind="r.FechaRecepcionPam" @bind:after="() => GuardarFila(r)" /></td>
                            <td>
                                <select class="ta-cell ta-w-md" disabled="@r.ProcesoBloqueado" @bind="r.RecibidaEnPamPor" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.RecibidaEnPamPor)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td>
                                <select class="ta-cell ta-w-sm @ClaseSiNo(r.ContactadoParaEntrega)" disabled="@r.ProcesoBloqueado" @bind="r.ContactadoParaEntrega" @bind:after="() => GuardarFila(r)">
                                    <option value="">—</option>
                                    @foreach (var v in Catalogos.SiNo)
                                    {
                                        <option value="@v">@v</option>
                                    }
                                </select>
                            </td>
                            <td><input type="date" class="ta-cell ta-cell-date" disabled="@r.ProcesoBloqueado" @bind="r.FechaEntrega" @bind:after="() => GuardarFila(r)" /></td>
                            <td class="sep-acciones">
                                @if (r.ProcesoBloqueado && Sesion.EsPrivilegiado)
                                {
                                    <button class="f8-btn" title="@r.MotivoBloqueo — Levantar el bloqueo administrativo"
                                            @onclick="() => Desbloquear(r)">Desbloquear</button>
                                }
                                <button class="f8-btn" @onclick="() => Editar(r.Id)">Editar</button>
                                <button class="f8-btn f8-btn-danger" @onclick="() => Eliminar(r.Id)">Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="f8-pag">
            <button disabled="@(PaginaActual <= 1)" @onclick="() => Ir(1)">«</button>
            <button disabled="@(PaginaActual <= 1)" @onclick="() => Ir(PaginaActual - 1)">‹</button>
            @foreach (var p in PaginasVisibles())
            {
                var pagina = p;
                <button class="@(pagina == PaginaActual ? "activo" : "")" @onclick="() => Ir(pagina)">@pagina</button>
            }
            <button disabled="@(PaginaActual >= TotalPaginas)" @onclick="() => Ir(PaginaActual + 1)">›</button>
            <button disabled="@(PaginaActual >= TotalPaginas)" @onclick="() => Ir(TotalPaginas)">»</button>
            <span style="margin-left:.5rem;font-size:.8rem;">
                @TotalResultados registros — página @PaginaActual de @TotalPaginas
            </span>
            <select value="@PageSize" @onchange="OnPageSizeChanged" class="f8-page-size-select">
                <option value="50">50 por página</option>
                <option value="100">100 por página</option>
                <option value="150">150 por página</option>
                <option value="200">200 por página</option>
            </select>
        </div>
    }
</div>
</AuthGuard>

@if (MostrarPegado)
{
    <div class="f8-modal-backdrop">
        <div class="f8-modal">
            <div class="f8-modal-header">
                Subir con Excel
                <button @onclick="CerrarPegado">✕</button>
            </div>
            <div class="f8-modal-body">
                <div style="margin-bottom:.75rem;">
                    <button class="f8-btn" @onclick="ExportarPlantilla">📥 Descargar plantilla</button>
                    <span style="font-size:.8rem;margin-left:.5rem;color:var(--ta-on-surface-variant);">
                        Llená la plantilla y subila abajo
                    </span>
                </div>

                <div style="margin-bottom:1rem;">
                    <label style="display:block;font-size:.8rem;font-weight:600;color:var(--ta-on-surface-variant);margin-bottom:.35rem;letter-spacing:.06em;">
                        LUGAR DE ATENCIÓN
                    </label>
                    <select @bind="LugarAtencionImport" class="ta-cell" style="width:100%;padding:.45rem .6rem;border-radius:6px;">
                        <option value="">— Seleccionar lugar (opcional) —</option>
                        @foreach (var lugar in Catalogos.LugaresAtencion)
                        {
                            <option value="@lugar">@lugar</option>
                        }
                    </select>
                    <span style="font-size:.72rem;color:var(--ta-on-surface-variant);margin-top:.25rem;display:block;">
                        Se aplica a todos los registros del archivo si no traen lugar en el Excel.
                    </span>
                </div>

                <div style="border:2px dashed var(--ta-outline);padding:1.5rem;text-align:center;border-radius:8px;margin-bottom:1rem;">
                    <div style="font-size:2rem;margin-bottom:.5rem;">📂</div>
                    <div style="margin-bottom:.75rem;">
                        <input type="file" accept=".xlsx" @onchange="OnFileSelected"
                               style="display:none;" id="excel-file-input" />
                        <button class="f8-btn f8-btn-primary" @onclick="() => SeleccionarArchivoExcel()">
                            Seleccionar archivo Excel
                        </button>
                    </div>
                    <div style="font-size:.8rem;color:var(--ta-on-surface-variant);">
                        o arrastrá y soltá un archivo .xlsx aquí
                    </div>
                    @if (!string.IsNullOrEmpty(NombreArchivoExcel))
                    {
                        <div style="margin-top:.75rem;font-size:.9rem;color:var(--ta-primary);">
                            ✅ @NombreArchivoExcel
                        </div>
                    }
                </div>

                <details style="font-size:.85rem;margin-bottom:.75rem;">
                    <summary style="cursor:pointer;color:var(--ta-on-surface-variant);">O pegar datos manualmente</summary>
                    <textarea @bind="TextoPegado" placeholder="Pega aquí las filas copiadas desde Excel..." style="min-height:6rem;margin-top:.5rem;"></textarea>
                </details>

                <p style="font-size:.8rem;color:var(--ta-error);margin-bottom:0;">
                    ⚠ ASISTE y TIPO DE LICENCIA deben ingresarse manualmente tras la importación.
                </p>
            </div>
            <div class="f8-modal-footer">
                <span style="font-size:.8rem;color:var(--ta-on-surface-variant);margin-right:auto;">
                    @if (RegistrosImportados > 0)
                    {
                        <text>✅ @RegistrosImportados registro(s) importados</text>
                    }
                </span>
                <button class="f8-btn" @onclick="CerrarPegado">Cerrar</button>
                <button class="f8-btn f8-btn-primary" @onclick="ProcesarPegado">Importar pegado</button>
            </div>
        </div>
    </div>
}

@if (MostrarPdf)
{
    <div class="f8-modal-backdrop">
        <div class="f8-modal">
            <div class="f8-modal-header">
                Descargar PDF
                <button @onclick="CerrarPdf">✕</button>
            </div>
            <div class="f8-modal-body">
                <p style="font-size:.8rem;">Elige el tipo de reporte:</p>
                <div class="ta-pdf-options" style="grid-template-columns:1fr 1fr 1fr;">
                    <button class="ta-pdf-option @(PdfOpcion == "ultima" ? "ta-pdf-option-active" : "")" @onclick='() => PdfOpcion = PdfOpcion == "ultima" ? "" : "ultima"' disabled="@GenerandoPdf">
                        <strong>ÚLTIMA CARPETA</strong>
                        <span>Nombre, RUT y FECHA ÚLTIMA CARPETA</span>
                    </button>
                    <button class="ta-pdf-option @(PdfOpcion == "penultima" ? "ta-pdf-option-active" : "")" @onclick='() => PdfOpcion = PdfOpcion == "penultima" ? "" : "penultima"' disabled="@GenerandoPdf">
                        <strong>PENÚLTIMA CARPETA</strong>
                        <span>Nombre, RUT y FECHA PENÚLTIMA CARPETA</span>
                    </button>
                    <button class="ta-pdf-option @(PdfOpcion == "impresas" ? "ta-pdf-option-active" : "")" @onclick='() => PdfOpcion = PdfOpcion == "impresas" ? "" : "impresas"' disabled="@GenerandoPdf">
                        <strong>IMPRESAS</strong>
                        <span>Por lugar de atención y funcionaria</span>
                    </button>
                </div>

                @if (PdfOpcion == "ultima" || PdfOpcion == "penultima")
                {
                    <div style="margin-top:1rem;">
                        <p style="font-size:.8rem;">¿Dónde se encuentra la carpeta?</p>
                        <div class="f8-field">
                            <select @bind="TipoListado">
                                <option value="">— Seleccionar ubicación —</option>
                                <option value="Oficina43">SE ENCUENTRA EN OF.43</option>
                                <option value="Archivos">SE ENCUENTRA EN ARCHIVOS</option>
                                <option value="NoSolicitadas">CARPETAS NO SOLICITADAS</option>
                                <option value="Todos">TODOS LOS REGISTROS</option>
                            </select>
                        </div>
                        <button class="f8-btn f8-btn-primary" style="width:100%;margin-top:.6rem;" @onclick="DescargarCarpetaPdf" disabled="@GenerandoPdf">
                            Generar PDF
                        </button>
                    </div>
                }

                @if (PdfOpcion == "impresas")
                {
                    <div class="f8-form-grid" style="margin-top:1rem;">
                        <div class="f8-field">
                            <label>LUGAR (ENCABEZADO DEL PDF)</label>
                            <select value="@PdfLugar" @onchange="OnPdfLugarChanged">
                                @foreach (var v in Catalogos.LugaresAtencion)
                                {
                                    <option value="@v">@v</option>
                                }
                            </select>
                        </div>
                        <div class="f8-field">
                            <label>FUNCIONARIA (IMPRESA POR)</label>
                            <select @bind="PdfFuncionaria">
                                <option value="">TODAS LAS DEL LUGAR</option>
                                @foreach (var v in Catalogos.ImpresaPor)
                                {
                                    <option value="@v">@v</option>
                                }
                            </select>
                        </div>
                        <div class="f8-field" style="display:flex;align-items:flex-end;">
                            <button class="f8-btn f8-btn-primary" style="width:100%;" @onclick="DescargarImpresas" disabled="@GenerandoPdf">
                                Generar PDF de impresas
                            </button>
                        </div>
                    </div>
                }

                @if (GenerandoPdf)
                {
                    <p style="font-size:.75rem;margin-top:.6rem;">Generando PDF...</p>
                }
            </div>
            <div class="f8-modal-footer">
                <button class="f8-btn" @onclick="CerrarPdf">Cancelar</button>
            </div>
        </div>
    </div>
}

@if (MostrarDominios)
{
    <div class="f8-modal-backdrop">
        <div class="f8-modal">
            <div class="f8-modal-header">
                Dominios de correo
                <button @onclick="() => MostrarDominios = false">✕</button>
            </div>
            <div class="f8-modal-body">
                <p style="font-size:.8rem;">
                    Estos dominios se sugieren automáticamente al escribir un correo
                    en cualquier campo del sistema.
                </p>
                @foreach (var d in Dominios)
                {
                    <div class="ta-domain-row">
                        <span>@@@d</span>
                        @if (!DominiosBase.Contains(d))
                        {
                            <button title="Quitar dominio" @onclick="() => QuitarDominio(d)">✕</button>
                        }
                    </div>
                }
                <div class="ta-domain-add">
                    <input placeholder="nuevodominio.cl" @bind="NuevoDominio" />
                    <button class="f8-btn f8-btn-primary" @onclick="AgregarDominio">Agregar</button>
                </div>
            </div>
            <div class="f8-modal-footer">
                <button class="f8-btn" @onclick="() => MostrarDominios = false">Cerrar</button>
            </div>
        </div>
    </div>
}


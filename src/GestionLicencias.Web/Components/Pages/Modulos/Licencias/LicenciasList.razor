    private async Task<List<TramiteLicencia>> ObtenerTodosActivos()
    {
        var (todos, _) = await ModuloService.BuscarAsync(new BusquedaFilter
        {
            Pagina = 1,
            PageSize = 100000
        });
        return todos.ToList();

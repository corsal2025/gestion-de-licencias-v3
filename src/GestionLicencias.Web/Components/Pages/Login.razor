@page "/login"
@rendermode InteractiveServer
@layout Layout.MainLayout
@inject UsuarioService Usuarios
@inject SesionUsuario Sesion
@inject NavigationManager Nav

<PageTitle>Iniciar sesión — Gestión de Licencias</PageTitle>

<div class="f8-wrapper f8-form" style="max-width:420px;margin:3rem auto;">
    <div class="f8-topbar">
        <h2>Iniciar sesión</h2>
    </div>

    @if (!string.IsNullOrEmpty(Mensaje))
    {
        <div class="f8-msg f8-msg-error">@Mensaje</div>
    }

    <fieldset>
        <legend>Credenciales</legend>
        <div class="f8-field">
            <label>USUARIO</label>
            <input @bind="NombreUsuario" @bind:event="oninput" @onkeyup="OnKeyUp" />
        </div>
        <div class="f8-field" style="margin-top:.6rem;">
            <label>CLAVE</label>
            <div style="position:relative;">
                <input type="@(MostrarClave ? "text" : "password")" @bind="Clave" @bind:event="oninput" @onkeyup="OnKeyUp" style="padding-right:2.4rem;" />
                <button type="button" @onclick="() => MostrarClave = !MostrarClave"
                        style="position:absolute;right:.5rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;padding:0;color:var(--ta-on-surface-variant);"
                        title="@(MostrarClave ? "Ocultar clave" : "Ver clave")">
                    @if (MostrarClave)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94"/>
                            <path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/>
                            <line x1="1" y1="1" x2="23" y2="23"/>
                        </svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    }
                </button>
            </div>
        </div>
    </fieldset>

    <div class="f8-actions" style="margin-top:1rem;">
        <button class="f8-btn f8-btn-primary" style="width:100%;" @onclick="Entrar" disabled="@Validando">
            @(Validando ? "Validando..." : "Entrar")
        </button>
    </div>
</div>

@code {
    private string NombreUsuario = "";
    private string Clave = "";
    private string Mensaje = "";
    private bool Validando = false;
    private bool MostrarClave = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Si ya hay sesión activa, ir directo al gestionador.
            var actual = await Sesion.CargarAsync();
            if (actual is not null)
                Nav.NavigateTo("/modulos/licencias", true);
        }
    }

    private async Task OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Entrar();
    }

    private async Task Entrar()
    {
        Validando = true;
        try
        {
            var usuario = await Usuarios.ValidarLoginAsync(NombreUsuario, Clave);
            if (usuario is null)
            {
                Mensaje = "Usuario o clave incorrectos, o usuario inactivo.";
                return;
            }

            await Sesion.IniciarAsync(new SesionUsuario.Info(
                usuario.Id, usuario.NombreUsuario, usuario.NombreCompleto, usuario.Rol));
            Nav.NavigateTo("/modulos/licencias", true);
        }
        finally
        {
            Validando = false;
        }
    }
}

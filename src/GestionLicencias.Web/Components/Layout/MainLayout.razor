@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <span class="ta-system-status">
                <span class="ta-status-dot"></span>
                ESTADO DEL SISTEMA: <strong>ACTIVO</strong>
            </span>
            <span class="ta-session-bar">
                <SessionBar />
            </span>
        </div>

        <article class="content px-4">
            @Body
        </article>

        <footer class="ta-ribbon">
            <span>// DIRECCIÓN DE TRÁNSITO :: GESTIÓN DE LICENCIAS :: MODELO POWERBI :: CONEXIÓN ESTABLE</span>
        </footer>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

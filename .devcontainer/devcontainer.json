{
  "name": "Gestión de Licencias",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "features": {
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "10"
    }
  },
  "updateContentCommand": "dotnet restore GestionLicencias.slnx",
  "remoteEnv": {
    "ConnectionStrings__DefaultConnection": "Data Source=/tmp/gestionlicencias.db"
  },
  "forwardPorts": [5029],
  "portsAttributes": {
    "5029": {
      "label": "Gestión de Licencias",
      "onAutoForward": "notify"
    }
  },
  "postStartCommand": "bash iniciar.sh"
}
